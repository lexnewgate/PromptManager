<Window x:Class="PromptManager.Views.CardEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:markdown="clr-namespace:Markdown.Xaml;assembly=Markdown.Xaml"
        mc:Ignorable="d"
        Title="编辑卡片" Height="560" Width="800"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Medium"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Window.Resources>
        <markdown:TextToFlowDocumentConverter x:Key="MarkdownConverter" />
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 名称 -->
        <TextBox Grid.Row="0" materialDesign:HintAssist.Hint="名称"
                 Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0,0,0,16" />

        <!-- 摘要 -->
        <TextBox Grid.Row="1" materialDesign:HintAssist.Hint="摘要"
                 Text="{Binding Summary, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 TextWrapping="Wrap" AcceptsReturn="True" MinLines="2" MaxLines="3"
                 Margin="0,0,0,16" />

        <!-- 内容：左侧编辑 + 右侧 Markdown 预览 -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="内容 (Markdown)"
                     Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     VerticalAlignment="Stretch" />
            <Border Grid.Column="1" Background="{DynamicResource MaterialDesignDivider}" />
            <Border Grid.Column="2" BorderBrush="{DynamicResource MaterialDesignTextFieldBoxBackground}"
                    BorderThickness="1" CornerRadius="4" Padding="8">
                <FlowDocumentScrollViewer x:Name="PreviewViewer" Padding="4"
                                          Document="{Binding Content, Converter={StaticResource MarkdownConverter}, Mode=OneWay}"
                                          VerticalScrollBarVisibility="Auto" />
            </Border>
        </Grid>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Style="{StaticResource MaterialDesignOutlinedButton}"
                    IsCancel="True" Click="CancelButton_OnClick" Margin="0,0,8,0" />
            <Button Content="确定" Style="{StaticResource MaterialDesignRaisedButton}"
                    IsDefault="True" Command="{Binding ConfirmCommand}" Click="OkButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
